# Airflow metadata DB (its own Postgres — never holds pipeline data)
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow
# Airflow Connection for TaskTracker API — env-var format (ADR-005).
# '@' in email must be percent-encoded as %40 — otherwise it will break URI parsing
# (there '@' is already taken as the separator for credentials/host).
# Example for admin@example.com / supersecret:
AIRFLOW_CONN_TASKTRACKER_API=http://admin%40example.com:supersecret@host.docker.internal:8000

# ClickHouse — dedicated user, NOT the `default` user (see docs/decisions.md ADR-004:
# the official image disables `default`'s network access unless one of
# CLICKHOUSE_USER/CLICKHOUSE_PASSWORD/CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT is set)
CLICKHOUSE_DB=flowhouse
CLICKHOUSE_USER=flowhouse
CLICKHOUSE_PASSWORD=flowhouse

# Where TaskTracker's API lives relative to this container.
# host.docker.internal, same pattern as petrag reaching Ollama on the host —
# see docs/decisions.md ADR-002.
TASKTRACKER_BASE_URL=http://host.docker.internal:8000
